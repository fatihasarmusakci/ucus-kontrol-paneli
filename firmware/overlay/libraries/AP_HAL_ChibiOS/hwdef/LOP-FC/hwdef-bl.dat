# LÖP FC Bootloader — Production HDL
MCU STM32F4xx STM32F405xx
APJ_BOARD_ID AP_HW_LOP_FC
OSCILLATOR_HZ 8000000
FLASH_SIZE_KB 1024
FLASH_RESERVE_START_KB 0
FLASH_BOOTLOADER_LOAD_KB 48

SERIAL_ORDER OTG1 USART1

PA11 OTG_FS_DM OTG1
PA12 OTG_FS_DP OTG1
PA13 JTMS-SWDIO SWD
PA14 JTCK-SWCLK SWD

# USART1 — MAVLink firmware upload / telemetri
PA9  USART1_TX USART1
PA10 USART1_RX USART1

PA4 IMU1_CS CS
PB12 FLASH1_CS CS

PC13 LED_BOOTLOADER OUTPUT LOW
define HAL_LED_ON 0
